# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# LogRocket (for Error Reporting)
# NEXT_PUBLIC_LOGROCKET_ID=

# EmailJS (for Contact form)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_USER_ID=

# Sanity (for Portfolio gallery)
# Create a project at https://sanity.io/manage
# NEXT_PUBLIC_PORTFOLIO_SANITY_PROJECT_ID=
# NEXT_PUBLIC_PORTFOLIO_SANITY_DATASET=production

# Sanity (for Blog)
# Create a project at https://sanity.io/manage
# NEXT_PUBLIC_BLOG_SANITY_PROJECT_ID=
# NEXT_PUBLIC_BLOG_SANITY_DATASET=production
